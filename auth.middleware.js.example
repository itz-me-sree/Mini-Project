/**
 * Node.js / Express Middleware for Token Verification
 * 
 * This is a reference implementation for your backend to ensure 
 * that guest users cannot perform protected actions even if they
 * bypass the frontend restrictions.
 */

const jwt = require('jsonwebtoken');

/**
 * Authentication Middleware
 * Protects routes from unauthorized access.
 */
const authMiddleware = (req, res, next) => {
    // 1. Get token from header
    const authHeader = req.headers.authorization;
    const token = authHeader && authHeader.split(' ')[1]; // Bearer TOKEN

    if (!token) {
        return res.status(401).json({ 
            success: false, 
            message: 'Access Denied: No token provided. Please login as a registered user.' 
        });
    }

    try {
        // 2. Verify token
        const verified = jwt.verify(token, process.env.TOKEN_SECRET);
        
        // 3. Attach user info to request
        req.user = verified;

        // 4. Deny Guest role if route is strictly for Users/Admins
        if (req.user.role === 'guest') {
             return res.status(403).json({
                 success: false,
                 message: 'Guest accounts do not have permission to perform this action.'
             });
        }

        next();
    } catch (err) {
        res.status(400).json({ 
            success: false, 
            message: 'Invalid Token' 
        });
    }
};

/**
 * Admin Middleware
 * Strictly for Admin-only routes.
 */
const adminMiddleware = (req, res, next) => {
    if (req.user && req.user.role === 'admin') {
        next();
    } else {
        res.status(403).json({
            success: false,
            message: 'Admin privileges required.'
        });
    }
};

module.exports = { authMiddleware, adminMiddleware };
